generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id           String        @id @default(cuid())
  name         String
  email        String?
  phone        String        @unique
  role         Role          @default(USER)
  createdAt    DateTime      @default(now())
  referralCode String        @unique
  orders       Order[]
  referrals    Referral[]
  tickets      Ticket[]
  adminTokens  Token[]       @relation("AdminTokens")
  tokens       Token[]
  products     UserProduct[] @relation("UserProducts")
}

model Product {
  id          String        @id @default(cuid())
  name        String
  description String
  price       Int
  capacity    String
  category    String
  images      String
  isActive    Boolean       @default(true)
  createdAt   DateTime      @default(now())
  orderItems  OrderItem[]
  users       UserProduct[] @relation("ProductUsers")
}

model Order {
  id              String      @id @default(cuid())
  orderNumber     String      @unique
  userId          String
  status          OrderStatus @default(NEW)
  address         String
  phone           String
  notes           String?
  warrantyCardUrl String?
  invoiceUrl      String?
  additionalFiles String?
  createdAt       DateTime    @default(now())
  user            User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  items           OrderItem[]
  tickets         Ticket[]
}

model OrderItem {
  id          String   @id @default(cuid())
  orderId     String
  productId   String?
  quantity    Int      @default(1)
  unitPrice   Int
  name        String
  description String
  capacity    String
  createdAt   DateTime @default(now())
  product     Product? @relation(fields: [productId], references: [id])
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
}

model Ticket {
  id          String       @id @default(cuid())
  userId      String
  orderId     String?
  category    String
  description String
  status      TicketStatus @default(OPEN)
  createdAt   DateTime     @default(now())
  order       Order?       @relation(fields: [orderId], references: [id])
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserProduct {
  id        String   @id @default(cuid())
  userId    String
  productId String
  createdAt DateTime @default(now())
  product   Product  @relation("ProductUsers", fields: [productId], references: [id], onDelete: Cascade)
  user      User     @relation("UserProducts", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
}

model Referral {
  id            Int      @id @default(autoincrement())
  referrerId    String
  name          String
  phone         String   @unique
  email         String
  product       String
  status        String   @default("pending")
  tokensAwarded Int      @default(0)
  submittedAt   DateTime @default(now())
  referrer      User     @relation(fields: [referrerId], references: [id])
}

model Token {
  id        String      @id @default(cuid())
  amount    Int
  status    TokenStatus @default(UNUSED)
  userId    String
  adminId   String?
  createdAt DateTime    @default(now())
  usedAt    DateTime?
  admin     User?       @relation("AdminTokens", fields: [adminId], references: [id])
  user      User        @relation(fields: [userId], references: [id])
}

enum TokenStatus {
  UNUSED
  USED
}

enum Role {
  USER
  ADMIN
}

enum OrderStatus {
  NEW
  CONTACTED
  CONFIRMED
  INSTALLED
  CANCELLED
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}
