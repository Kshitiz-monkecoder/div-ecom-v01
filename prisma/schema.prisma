generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id        String        @id @default(cuid())
  name      String
  email     String?
  phone     String        @unique
  role      Role          @default(USER)
  createdAt DateTime      @default(now())
  orders    Order[]
  tickets   Ticket[]
  referralCode String   @unique
  products  UserProduct[] @relation("UserProducts")
  tokens        Token[]
  adminTokens Token[] @relation("AdminTokens")
}

model Product {
  id          String        @id @default(cuid())
  name        String
  description String
  price       Int
  capacity    String
  category    String
  images      String
  isActive    Boolean       @default(true)
  createdAt   DateTime      @default(now())
  orderItems  OrderItem[]
  users       UserProduct[] @relation("ProductUsers")
}

model Order {
  id              String      @id @default(cuid())
  orderNumber     String      @unique
  userId          String
  status          OrderStatus @default(NEW)
  address         String
  phone           String
  notes           String?
  warrantyCardUrl String?
  invoiceUrl      String?
  additionalFiles String?
  createdAt       DateTime    @default(now())
  user            User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  items           OrderItem[]
  tickets         Ticket[]
}

model OrderItem {
  id          String   @id @default(cuid())
  orderId     String
  productId   String?
  quantity    Int      @default(1)
  unitPrice   Int
  name        String
  description String
  capacity    String
  createdAt   DateTime @default(now())
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product     Product? @relation(fields: [productId], references: [id])

  @@index([orderId])
}

model Ticket {
  id          String       @id @default(cuid())
  userId      String
  orderId     String?
  category    String
  description String
  status      TicketStatus @default(OPEN)
  createdAt   DateTime     @default(now())
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  order       Order?       @relation(fields: [orderId], references: [id])
}

model UserProduct {
  id        String   @id @default(cuid())
  userId    String
  productId String
  createdAt DateTime @default(now())
  user      User     @relation("UserProducts", fields: [userId], references: [id], onDelete: Cascade)
  product   Product  @relation("ProductUsers", fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
}

model Referral {
  id            Int      @id @default(autoincrement())
  name          String
  phone         String
  email         String
  product       String
  referralCode  String?
  status        String   @default("pending")
  tokensAwarded Int      @default(0)
  submittedAt   DateTime @default(now())
}

model Token {
  id        String      @id @default(cuid())
  amount    Int
  status    TokenStatus @default(UNUSED)
  userId    String      // user who gets the token
  adminId   String      // admin who approves the referral
  createdAt DateTime    @default(now())
  usedAt    DateTime?   // optional, when redeemed

  user      User        @relation(fields: [userId], references: [id])
  admin     User        @relation("AdminTokens", fields: [adminId], references: [id])
}

enum TokenStatus {
  UNUSED
  USED
}


enum Role {
  USER
  ADMIN
}

enum OrderStatus {
  NEW
  CONTACTED
  CONFIRMED
  INSTALLED
  CANCELLED
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}
